<Window x:Class="resrater_adminfelulet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:resrater_adminfelulet.Views"
        mc:Ignorable="d"
        Title="ResRater Admin Panel" Height="680" Width="1050"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- Menu bar at the top -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Exit" Click="MenuExit_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main content area -->
        <Grid Background="#F0F0F0">
            <Grid.RowDefinitions>
                <!-- Header banner -->
                <RowDefinition Height="50"/>
                <!-- Tab control fills remaining space -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header banner -->
            <Border Grid.Row="0" Background="#2C3E50">
                <TextBlock Text="ResRater Admin Panel"
                           Foreground="White" FontSize="20" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </Border>

            <!-- Tab control with 3 tabs - each tab hosts a UserControl from the Views folder -->
            <TabControl Grid.Row="1" Margin="10" Background="White">

                <!-- Dashboard tab - shows statistics -->
                <TabItem Header="Dashboard">
                    <views:DashboardTab/>
                </TabItem>

                <!-- Users tab - user management -->
                <TabItem Header="Users">
                    <views:UsersTab/>
                </TabItem>

                <!-- Restaurants tab - restaurant management -->
                <TabItem Header="Restaurants">
                    <views:RestaurantsTab/>
                </TabItem>

            </TabControl>
        </Grid>

    </DockPanel>
</Window>
