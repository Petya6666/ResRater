<Window x:Class="resrater_adminfelulet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:resrater_adminfelulet.Views"
        mc:Ignorable="d"
        Title="ResRater Admin Panel" Height="680" Width="1050"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- Menu bar at the top -->
        <Menu DockPanel.Dock="Top" Background="#FF370B0B">
            <MenuItem Header="_Fájl">
                <MenuItem Header="_Kilépés" Click="MenuExit_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main content area -->
        <Grid Background="#FF370B0B">
            <Grid.RowDefinitions>
                <!-- Header banner -->
                <RowDefinition Height="50"/>
                <!-- Tab control fills remaining space -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header banner -->
            <Border Grid.Row="0" Background="#FF370B0B">
                <DockPanel VerticalAlignment="Center" Margin="20,0,20,0">

                    <!-- Left side: logo + title -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Image Source="/Assets/logo.png" Width="140" Height="100"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Panel.ZIndex="-10" Margin="0,5,0,0"/>
                        <TextBlock Text="Admin Panel"
                                   Foreground="White" FontSize="20" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right side: logged-in user + logout button -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="lblAdminNev"
                                   Foreground="White" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button x:Name="btnKijelentkezes"
                                Content="Kijelentkezés"
                                Width="110" Height="30"
                                FontSize="12"
                                Background="#FF6B1A1A"
                                Foreground="White"
                                BorderBrush="#FFAA4444"
                                Click="btnKijelentkezes_Click"/>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- Tab control with 3 tabs - each tab hosts a UserControl from the Views folder -->
            <TabControl Grid.Row="1" Margin="10" Background="White">

                <!-- Dashboard tab - shows statistics -->
                <TabItem Header="Irányítópult">
                    <views:DashboardTab/>
                </TabItem>

                <!-- Users tab - user management -->
                <TabItem Header="Felhasználók">
                    <views:UsersTab/>
                </TabItem>

                <!-- Restaurants tab - restaurant management -->
                <TabItem Header="Éttermek">
                    <views:RestaurantsTab/>
                </TabItem>

            </TabControl>
        </Grid>

    </DockPanel>
</Window>
