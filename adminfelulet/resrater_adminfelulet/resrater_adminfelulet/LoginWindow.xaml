<Window x:Class="resrater_adminfelulet.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ResRater Admin – Bejelentkezés"
        Height="380" Width="420"
        MinHeight="380" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF370B0B">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Logo -->
            <RowDefinition Height="120"/>
            <!-- Form -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo at the top -->
        <Image Grid.Row="0"
               Source="/Assets/logo.png"
               Width="110" Height="100"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Margin="0,10,0,0"/>

        <!-- Login form -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="300"
                    Margin="0,0,0,20">

            <!-- Username label + input -->
            <TextBlock Text="Felhasználónév:"
                       Foreground="White"
                       FontSize="13"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="txtFelhasznev"
                     Height="32"
                     FontSize="13"
                     Padding="6,4"
                     Margin="0,0,0,12"/>

            <!-- Password label + input -->
            <TextBlock Text="Jelszó:"
                       Foreground="White"
                       FontSize="13"
                       Margin="0,0,0,4"/>
            <PasswordBox x:Name="pwbJelszo"
                         Height="32"
                         FontSize="13"
                         Padding="6,4"
                         Margin="0,0,0,12"/>

            <!-- Error message (hidden until needed) -->
            <TextBlock x:Name="lblHiba"
                       Foreground="#FFFF6B6B"
                       FontSize="12"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"
                       Visibility="Collapsed"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button x:Name="btnBejelentkezes"
                        Content="Bejelentkezés"
                        Width="130" Height="34"
                        FontSize="13"
                        Background="#FF6B1A1A"
                        Foreground="White"
                        BorderBrush="#FFAA4444"
                        Margin="0,0,12,0"
                        Click="btnBejelentkezes_Click"/>

                <Button x:Name="btnMegse"
                        Content="Mégse"
                        Width="90" Height="34"
                        FontSize="13"
                        Background="#FF4A1010"
                        Foreground="White"
                        BorderBrush="#FFAA4444"
                        Click="btnMegse_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
