<UserControl x:Class="resrater_adminfelulet.Views.RestaurantsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Search / toolbar row -->
            <RowDefinition Height="Auto"/>
            <!-- DataGrid -->
            <RowDefinition Height="*"/>
            <!-- Edit form -->
            <RowDefinition Height="Auto"/>
            <!-- Action buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search bar and Refresh button -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Keresés név szerint:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="txtSearch"
                     Width="200" Height="28"
                     TextChanged="txtSearch_TextChanged"/>
            <Button Content="Frissítés"
                    Width="80" Height="28" Margin="10,0,0,0"
                    Click="btnRefresh_Click"/>
        </StackPanel>

        <!-- Restaurants DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="dgRestaurants"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  AlternatingRowBackground="#F5F5F5"
                  GridLinesVisibility="Horizontal"
                  SelectionChanged="dgRestaurants_SelectionChanged"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"            Binding="{Binding RestaurantId}" Width="60"/>
                <DataGridTextColumn Header="Név"          Binding="{Binding Name}"         Width="180"/>
                <DataGridTextColumn Header="Telefon"      Binding="{Binding Phone}"        Width="130"/>
                <DataGridTextColumn Header="Kategória"    Binding="{Binding CategoryId}"   Width="90"/>
                <DataGridTextColumn Header="Irányítószám" Binding="{Binding PostalCode}"   Width="100"/>
                <DataGridTextColumn Header="Jóváhagyott"  Binding="{Binding IsApprovedText}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Edit / Add form - fields are filled when a row is selected -->
        <GroupBox Grid.Row="2" Header="Étterem adatai" Margin="0,0,0,10" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Név:"          VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtName"    Height="26" Margin="0,4"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Telefon:"     VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox   Grid.Row="0" Grid.Column="4" x:Name="txtPhone"   Height="26" Margin="0,4"/>

                <!-- Row 1 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Kategória ID:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtCategory" Height="26" Margin="0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="3" Text="Irányítószám:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox   Grid.Row="1" Grid.Column="4" x:Name="txtPostalCode" Height="26" Margin="0,4"/>

                <!-- Row 2 - description spans full width -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Leírás:"      VerticalAlignment="Top"    Margin="0,4,8,4"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4"
                           x:Name="txtDescription"
                           Height="50" Margin="0,4"
                           TextWrapping="Wrap" AcceptsReturn="True"/>
            </Grid>
        </GroupBox>

        <!-- Action buttons -->
        <WrapPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Új étterem hozzáadása"
                    Width="150" Height="30" Margin="0,0,8,0"
                    Background="#2ECC71" Foreground="White"
                    Click="btnAddRestaurant_Click"/>

            <Button Content="Étterem szerkesztése"
                    Width="130" Height="30" Margin="0,0,8,0"
                    Background="#3498DB" Foreground="White"
                    Click="btnEditRestaurant_Click"/>

            <Button Content="Jóváhagyás / Visszavonás"
                    Width="160" Height="30" Margin="0,0,8,0"
                    Background="#F39C12" Foreground="White"
                    Click="btnToggleApproval_Click"/>

            <Button Content="Étterem törlése"
                    Width="140" Height="30" Margin="0,0,8,0"
                    Background="#E74C3C" Foreground="White"
                    Click="btnDeleteRestaurant_Click"/>
        </WrapPanel>

    </Grid>
</UserControl>
