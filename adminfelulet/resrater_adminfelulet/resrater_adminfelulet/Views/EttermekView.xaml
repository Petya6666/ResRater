<UserControl x:Class="resrater_adminfelulet.Views.EttermekView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🍽️ Étterem-kezelés" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,12"/>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="1" Content="🔍 Keresés" Command="{Binding SearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0"/>
            </Grid>

            <Button Grid.Column="3" Content="🔄 Frissítés" Command="{Binding LoadCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"/>
            <Button Grid.Column="5" Content="➕ Új étterem" Command="{Binding AddNewCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Grid.Column="7" Content="✏️ Szerkesztés" Command="{Binding StartEditCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"/>
            <Button Grid.Column="9" Content="✅ Jóváhagyás" Command="{Binding ApproveCommand}"
                    Style="{StaticResource SuccessButtonStyle}"/>
            <Button Grid.Column="11" Content="🗑️ Törlés" Command="{Binding DeleteCommand}"
                    Style="{StaticResource DangerButtonStyle}"/>
        </Grid>

        <!-- Main Content: List + Edit Panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="340" MinWidth="280">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Width" Value="340"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Ettermek}"
                      SelectedItem="{Binding SelectedEtterem}"
                      Style="{StaticResource AdminDataGridStyle}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding EtteremId}" Width="50"/>
                    <DataGridTextColumn Header="Név" Binding="{Binding Nev}" Width="160"/>
                    <DataGridTextColumn Header="Kategória" Binding="{Binding KategoriaNev}" Width="100"/>
                    <DataGridTextColumn Header="Város" Binding="{Binding VarosNev}" Width="100"/>
                    <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="120"/>
                    <DataGridTemplateColumn Header="Státusz" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="6,2" CornerRadius="10" HorizontalAlignment="Left" Margin="4,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFF3CD"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Jovahagyott}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding JovahagyottSzoveg}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#E65100"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Jovahagyott}" Value="True">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Edit Panel -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibleConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding IsAddingNew, Converter={StaticResource BoolToAddEditConverter}}"
                                   Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Név *" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditNev, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}"/>

                        <TextBlock Text="Telefon" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditTelefon, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}"/>

                        <TextBlock Text="Leírás" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditLeiras, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" TextWrapping="Wrap"
                                 AcceptsReturn="True" Height="80" VerticalScrollBarVisibility="Auto"/>

                        <TextBlock Text="Kategória" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Kategoriak}"
                                  SelectedItem="{Binding SelectedKategoria}"
                                  DisplayMemberPath="KategoriaNev"
                                  Style="{StaticResource FormComboBoxStyle}"/>

                        <TextBlock Text="Város" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Varosok}"
                                  SelectedItem="{Binding SelectedVaros}"
                                  DisplayMemberPath="VarosNev"
                                  Style="{StaticResource FormComboBoxStyle}"/>

                        <CheckBox Content="Jóváhagyott" IsChecked="{Binding EditJovahagyott}"
                                  Margin="0,10,0,16" FontSize="13"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="💾 Mentés" Command="{Binding SaveEditCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button Grid.Column="2" Content="✖ Mégse" Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="100" Height="4"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibleConverter}}"/>
        </Grid>
    </Grid>
</UserControl>
