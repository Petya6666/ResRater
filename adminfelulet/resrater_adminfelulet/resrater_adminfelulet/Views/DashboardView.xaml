<UserControl x:Class="resrater_adminfelulet.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📊 Irányítópult" Style="{StaticResource HeaderTextStyle}" Margin="0,0,0,16"/>

        <!-- Stats Cards -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,20">
            <!-- Users -->
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="👥" FontSize="28" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalFelhasznalok}" FontSize="36" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Felhasználók" Style="{StaticResource CardLabelStyle}"/>
                </StackPanel>
            </Border>
            <!-- Restaurants -->
            <Border Style="{StaticResource StatCardStyle}" Margin="4,0,4,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🍽️" FontSize="28" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalEttermek}" FontSize="36" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Éttermek" Style="{StaticResource CardLabelStyle}"/>
                </StackPanel>
            </Border>
            <!-- Ratings -->
            <Border Style="{StaticResource StatCardStyle}" Margin="4,0,4,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⭐" FontSize="28" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalErtekelesek}" FontSize="36" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Értékelések" Style="{StaticResource CardLabelStyle}"/>
                </StackPanel>
            </Border>
            <!-- Comments -->
            <Border Style="{StaticResource StatCardStyle}" Margin="4,0,4,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="💬" FontSize="28" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalKommentek}" FontSize="36" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Kommentek" Style="{StaticResource CardLabelStyle}"/>
                </StackPanel>
            </Border>
            <!-- Pending -->
            <Border Style="{StaticResource StatCardStyle}" Margin="8,0,0,0"
                    Background="#FFF3CD">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⏳" FontSize="28" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding PendingEttermek}" FontSize="36" FontWeight="Bold"
                               Foreground="#E67E22" HorizontalAlignment="Center"/>
                    <TextBlock Text="Jóváhagyásra vár" Style="{StaticResource CardLabelStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Content: Category Chart + Recent Activity -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Category Distribution -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Éttermek kategóriánként" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding KategoriaStatisztikak}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Nev}" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding Darab}" Maximum="10"
                                                 Height="18" Foreground="{StaticResource AccentBrush}"
                                                 Background="#E8ECF0" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Darab}" VerticalAlignment="Center"
                                               FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Recent Activity -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Legutóbbi tevékenység" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding RecentActivity}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,3,0,3" Padding="10,8" Background="#F8F9FA"
                                        CornerRadius="6">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="(Nincs közelmúltbeli tevékenység)" FontStyle="Italic"
                               Foreground="Gray" FontSize="12" Margin="4"
                               Visibility="{Binding RecentActivity.Count, Converter={StaticResource ZeroToVisibleConverter}}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="Gray"
                   FontSize="11" Margin="0,8,0,0" HorizontalAlignment="Right"/>
    </Grid>
</UserControl>
