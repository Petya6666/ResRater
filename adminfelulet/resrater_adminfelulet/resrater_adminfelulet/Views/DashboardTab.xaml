<UserControl x:Class="resrater_adminfelulet.Views.DashboardTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Title row -->
            <RowDefinition Height="Auto"/>
            <!-- Statistics cards row -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page title -->
        <TextBlock Grid.Row="0"
                   Text="Dashboard - Statistics"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Four statistic cards displayed side by side -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal">

            <!-- Total Users card -->
            <Border Width="180" Height="110" Background="#FFDC0000" CornerRadius="8" Margin="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Total Users"
                               Foreground="White" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalUsers"
                               Text="0"
                               Foreground="White" FontSize="36" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Total Restaurants card -->
            <Border Width="180" Height="110" Background="#FFB50000" CornerRadius="8" Margin="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Total Restaurants"
                               Foreground="White" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalRestaurants"
                               Text="0"
                               Foreground="White" FontSize="36" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Total Ratings card -->
            <Border Width="180" Height="110" Background="#FF8A0D00" CornerRadius="8" Margin="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Total Ratings"
                               Foreground="White" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalRatings"
                               Text="0"
                               Foreground="White" FontSize="36" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Total Comments card -->
            <Border Width="180" Height="110" Background="#FF620000" CornerRadius="8" Margin="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Total Comments"
                               Foreground="White" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalComments"
                               Text="0"
                               Foreground="White" FontSize="36" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </WrapPanel>
    </Grid>
</UserControl>
